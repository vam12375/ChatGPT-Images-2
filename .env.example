# 单个密钥或多个密钥（用逗号分隔以支持轮转）
OPENAI_API_KEY=sk-your-api-key
# OPENAI_API_KEYS=sk-key-1,sk-key-2,sk-key-3

# 图片生成模型（Images API）
OPENAI_IMAGE_MODEL=gpt-image-2

# Responses API 主模型（切换到 Responses API 时使用）
OPENAI_RESPONSES_MODEL=gpt-5.3-codex

# 填入中转 API 地址 (注意：通常需要包含 /v1 后缀)
OPENAI_BASE_URL=

# 图片编辑专用上游地址；不配置时 Images API 编辑默认使用 API易兼容端点
OPENAI_IMAGE_EDIT_BASE_URL=
OPENAI_RESPONSES_EDIT_BASE_URL=

# 远程图片历史落盘白名单；留空时不会主动拉取远程图片 URL
OPENAI_IMAGE_PERSIST_ALLOWED_HOSTS=
OPENAI_IMAGE_PERSIST_MAX_BYTES=8388608

# 代理配置
ENABLE_PROXY_CACHE=true
PROXY_CACHE_DURATION=3600
PROXY_CACHE_MAX_ENTRIES=50
ENABLE_REQUEST_LOG=true

# 本地防滥用配置
IMAGE_RATE_LIMIT_MAX=10
IMAGE_RATE_LIMIT_WINDOW_MS=60000

# 代理监控接口访问令牌（访问 /api/proxy/stats 时需要；必须替换为强随机值）
PROXY_ADMIN_TOKEN=replace-with-long-random-token
